# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_here

# Express Session Security
SESSION_SECRET=your_session_secret_key_here

# Server Configuration
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=*

# Firebase Configuration
FIRESTORE_PREFER_REST=true
# Paste your entire service account JSON here as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# PCRemote Standalone JWT Configuration
PCREMOTE_JWT_SECRET=your_pcremote_jwt_secret_here

# Optional Discord Integration Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
